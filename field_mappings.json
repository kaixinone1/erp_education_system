    "创建时间": "created_at",
    "更新时间": "updated_at"
  },
  "validation_rules": {
    "id_card": {
      "pattern": "^\\d{17}[\\dXx]$",
      "message": "身份证号码格式不正确"
    },
    "phone": {
      "pattern": "^1[3-9]\\d{9}$",
      "message": "手机号码格式不正确"
    },
    "email": {
      "pattern": "^[\\w-]+(\\.[\\w-]+)*@[\\w-]+(\\.[\\w-]+)+$",
      "message": "邮箱格式不正确"
    }
  }
